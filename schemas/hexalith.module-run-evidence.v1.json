{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hexalith.dev/schemas/hexalith.module-run-evidence.v1.json",
  "title": "Hexalith module run evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "runId",
    "timestamps",
    "environment",
    "invocation",
    "topology",
    "phaseOutcomes",
    "testCounts",
    "artifactHashes",
    "finalStatus",
    "outcome",
    "volatileFields"
  ],
  "properties": {
    "schema": { "const": "hexalith.module-run-evidence.v1" },
    "runId": { "type": "string", "pattern": "^[a-f0-9]{32}$" },
    "timestamps": { "$ref": "#/$defs/timestamps" },
    "environment": { "$ref": "#/$defs/environment" },
    "invocation": { "$ref": "#/$defs/invocation" },
    "topology": { "$ref": "#/$defs/topology" },
    "phaseOutcomes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/phaseOutcome" }
    },
    "testCounts": { "$ref": "#/$defs/testCounts" },
    "artifactHashes": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[A-F0-9]{64}$" }
    },
    "finalStatus": { "enum": ["completed", "failed", "unavailable", "cancelled"] },
    "outcome": { "$ref": "#/$defs/outcome" },
    "volatileFields": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "persistedAssertions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expectedSequences": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startedUtc", "completedUtc"],
      "properties": {
        "startedUtc": { "type": "string", "format": "date-time" },
        "completedUtc": { "type": "string", "format": "date-time" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repositoryRevision", "repositoryDirtyMarker", "sdkVersion", "operatingSystem", "toolVersion"],
      "properties": {
        "repositoryRevision": { "type": "string" },
        "repositoryDirtyMarker": { "enum": ["clean", "dirty", "unknown"] },
        "sdkVersion": { "type": "string" },
        "operatingSystem": { "type": "string" },
        "toolVersion": { "type": "string" }
      }
    },
    "invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "manifestPath", "manifestHash", "profile", "fixturePath", "fixtureHash", "filterHash"],
      "properties": {
        "command": { "type": "string" },
        "manifestPath": { "type": ["string", "null"] },
        "manifestHash": { "type": ["string", "null"] },
        "profile": { "type": ["string", "null"] },
        "fixturePath": { "type": ["string", "null"] },
        "fixtureHash": { "type": ["string", "null"] },
        "filterHash": { "type": ["string", "null"] }
      }
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modules", "platform"],
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "domain", "applicationId", "resourceId", "descriptorAssembly"],
            "properties": {
              "id": { "type": "string" },
              "domain": { "type": "string" },
              "applicationId": { "type": "string" },
              "resourceId": { "type": "string" },
              "descriptorAssembly": { "type": "string" }
            }
          }
        },
        "platform": {
          "type": ["object", "null"],
          "properties": {
            "eventStoreVersion": { "type": "string" },
            "daprRuntimeVersion": { "type": "string" },
            "daprSdkVersion": { "type": "string" },
            "frontComposerVersion": { "type": "string" }
          }
        }
      }
    },
    "phaseOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "category", "ruleId"],
      "properties": {
        "phase": { "type": "string" },
        "category": { "type": "string" },
        "ruleId": { "type": ["string", "null"] }
      }
    },
    "testCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reported", "total", "passed", "failed", "skipped"],
      "properties": {
        "reported": { "type": "boolean" },
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exitCode", "phase", "category", "ruleId"],
      "properties": {
        "exitCode": { "enum": [0, 1, 2, 3, 4, 5, 6, 130] },
        "phase": { "type": "string" },
        "category": { "type": "string" },
        "ruleId": { "type": ["string", "null"] }
      }
    }
  }
}
