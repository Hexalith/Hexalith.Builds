{
  "name": "hexalith-builds",
  "version": "0.0.0-development",
  "private": true,
  "description": "Hexalith Build assets",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hexalith/Hexalith.Builds.git"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "pwsh -NoProfile -File ./Tools/test-g4-tool-package-contracts.ps1 -Version ${nextRelease.version} -PackageDirectory artifacts/g4-tool-packages/${nextRelease.version} -RetainPackageDirectory -RequireControls",
          "publishCmd": "pwsh -NoProfile -File ./Tools/publish-g4-tool-packages.ps1 -Version ${nextRelease.version}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "artifacts/g4-tool-packages/**/g4-tool-package-inventory.json",
              "label": "G-4 tool package SHA-256 inventory"
            }
          ]
        }
      ]
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.8",
    "semantic-release": "^25.0.5"
  }
}
