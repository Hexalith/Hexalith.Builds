{
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "pwsh -File references/Hexalith.Builds/Github/scripts/build-packages.ps1 -Version ${nextRelease.version}",
        "publishCmd": "pwsh -File references/Hexalith.Builds/Github/scripts/publish-packages.ps1 -Version ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
